# HYPERION Configuration
# Copy this to .env and fill in your values

# API Key (supports OpenAI, OpenRouter, etc.)
HYPERION_API_KEY=sk-or-v1-your-key-here

# Backend: openai, openrouter, or ollama
HYPERION_BACKEND=openrouter

# Model name
HYPERION_MODEL=openrouter/auto

# API Base URL
# For OpenAI: https://api.openai.com/v1
# For OpenRouter: https://openrouter.ai/api/v1
# For local Ollama: http://localhost:11434
HYPERION_BASE_URL=https://openrouter.ai/api/v1

# Max tokens for each LLM call
HYPERION_MAX_TOKENS=16384

# Reasoning depth (1-10, higher = deeper thinking)
HYPERION_REASONING_DEPTH=3

# Number of exploration paths (1-5)
HYPERION_EXPLORATION_PATHS=3

# Number of self-critique rounds (1-3)
HYPERION_CRITIC_ROUNDS=2
