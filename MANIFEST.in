include README.md
include LICENSE
include CHANGELOG.md
include CONTRIBUTING.md
include CODE_OF_CONDUCT.md
include SECURITY.md
include requirements.txt
include pyproject.toml

recursive-include hyperion/prompts *.txt
recursive-include hyperion/visual *.html
recursive-include hyperion *.py
recursive-include examples *.py
recursive-include tests *.py
recursive-include .github *.yml

exclude .git
exclude __pycache__
exclude *.pyc
exclude *.pyo
exclude .pytest_cache
exclude .coverage
exclude .hyperion_cache
exclude .hyperion_memory
